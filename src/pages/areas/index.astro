---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { getCollection } from "astro:content";

const areas = (await getCollection("areas")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Service Areas — Westside Cat & Dog Grooming"
  description="The Pet Affaire serves Santa Monica, Pacific Palisades, Venice, Brentwood, and Mar Vista — gentle, hand-finished cat and dog grooming with honest neighborhood pricing."
>
  <Section
    eyebrow="Service areas"
    title="Where our clients drive in from."
    intro="We're based on Lincoln Boulevard in Santa Monica, and a short drive for most of the Westside. A few neighborhoods we see often:"
  >
    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {areas.map((a) => (
        <li>
          <a
            href={`/areas/${a.id}/`}
            class="group flex h-full flex-col rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md"
          >
            <h2 class="font-display text-2xl group-hover:underline">{a.data.title}</h2>
            <p class="mt-3 flex-1 text-sm text-black/70">{a.data.intro}</p>
            <p class="mt-4 text-xs uppercase tracking-wider text-black/55">{a.data.driveNote}</p>
            <p class="mt-4 text-sm underline underline-offset-4">Details →</p>
          </a>
        </li>
      ))}
    </ul>
  </Section>
</BaseLayout>
