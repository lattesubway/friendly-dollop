---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { getCollection, render } from "astro:content";

const all = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const dogs = all.filter((s) => s.data.species === "dog" || s.data.species === "both");
const cats = all.filter((s) => s.data.species === "cat" || s.data.species === "both");
---

<BaseLayout title="Services & Pricing" description="Cat and dog grooming services, prices, and what's included — at The Pet Affaire in Santa Monica.">
  <Section
    eyebrow="Services"
    title="Hand-finished grooming, fairly priced."
    intro="Prices start from. Final pricing is set in person and depends on size, coat condition, and any add-ons. We'll always confirm before we begin."
  >
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl border-b border-black/10 pb-3">For dogs</h2>
        <ul class="mt-6 space-y-8">
          {dogs.map(async (s) => {
            const { Content } = await render(s);
            return (
              <li class="rounded-2xl border border-black/10 bg-white p-6">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="font-display text-2xl">{s.data.title}</h3>
                  {s.data.priceFrom && (
                    <p class="whitespace-nowrap text-sm">
                      <span class="text-black/55">from</span>
                      <span class="ml-1 font-medium">${s.data.priceFrom}</span>
                    </p>
                  )}
                </div>
                {s.data.duration && <p class="mt-1 text-xs uppercase tracking-wider text-black/50">{s.data.duration}</p>}
                <p class="mt-3 text-sm text-black/75">{s.data.summary}</p>
                {s.data.includes.length > 0 && (
                  <ul class="mt-4 space-y-1 text-sm text-black/70">
                    {s.data.includes.map((i) => <li class="flex gap-2"><span class="text-[var(--color-clay)]">·</span> {i}</li>)}
                  </ul>
                )}
                <div class="mt-4 prose prose-sm max-w-none text-black/70">
                  <Content />
                </div>
                {s.data.priceNote && <p class="mt-4 text-xs text-black/50">{s.data.priceNote}</p>}
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h2 class="font-display text-2xl border-b border-black/10 pb-3">For cats</h2>
        <ul class="mt-6 space-y-8">
          {cats.map(async (s) => {
            const { Content } = await render(s);
            return (
              <li class="rounded-2xl border border-black/10 bg-white p-6">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="font-display text-2xl">{s.data.title}</h3>
                  {s.data.priceFrom && (
                    <p class="whitespace-nowrap text-sm">
                      <span class="text-black/55">from</span>
                      <span class="ml-1 font-medium">${s.data.priceFrom}</span>
                    </p>
                  )}
                </div>
                {s.data.duration && <p class="mt-1 text-xs uppercase tracking-wider text-black/50">{s.data.duration}</p>}
                <p class="mt-3 text-sm text-black/75">{s.data.summary}</p>
                {s.data.includes.length > 0 && (
                  <ul class="mt-4 space-y-1 text-sm text-black/70">
                    {s.data.includes.map((i) => <li class="flex gap-2"><span class="text-[var(--color-clay)]">·</span> {i}</li>)}
                  </ul>
                )}
                <div class="mt-4 prose prose-sm max-w-none text-black/70">
                  <Content />
                </div>
                {s.data.priceNote && <p class="mt-4 text-xs text-black/50">{s.data.priceNote}</p>}
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </Section>

  <Section bg="bone" eyebrow="Good to know" title="A few honest notes.">
    <ul class="grid gap-6 md:grid-cols-2 text-[15px] leading-relaxed text-black/75">
      <li><strong class="text-black">We don't kennel.</strong> Pets are with us for their appointment window only — no all-day waits.</li>
      <li><strong class="text-black">No drying cages.</strong> Every dog and cat is hand-dried.</li>
      <li><strong class="text-black">Vaccinations.</strong> Rabies and DHPP for dogs, FVRCP for cats. Bring proof at the first visit.</li>
      <li><strong class="text-black">Late & no-show.</strong> A 50% fee for no-shows or cancellations under 24 hours, so we can keep prices fair.</li>
    </ul>
  </Section>
</BaseLayout>
