---
import { Picture } from "astro:assets";
import type { GalleryItem } from "@/data/gallery";

interface Props {
  items: GalleryItem[];
  /** Aspect of each tile. Defaults to square. */
  aspect?: "square" | "landscape" | "portrait";
}
const { items, aspect = "landscape" } = Astro.props;

const aspectClass =
  aspect === "square"
    ? "aspect-square"
    : aspect === "portrait"
    ? "aspect-[4/5]"
    : "aspect-[5/4]";
---
<ul class={`grid gap-3 md:gap-4 ${items.length === 4 ? "grid-cols-2 md:grid-cols-4" : "grid-cols-3"}`}>
  {items.map((p) => (
    <li class="overflow-hidden rounded-2xl bg-[var(--color-bone)]">
      <figure class={`group relative ${aspectClass}`}>
        <Picture
          src={p.src}
          formats={["avif", "webp"]}
          alt={p.alt}
          widths={[280, 420, 560]}
          sizes="(max-width: 640px) 33vw, (max-width: 1024px) 30vw, 280px"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
        />
        <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-3 text-[11px] uppercase tracking-wider text-white opacity-0 transition group-hover:opacity-100">
          {p.caption}
        </figcaption>
      </figure>
    </li>
  ))}
</ul>
