---
import { NAV, SITE } from "@/consts";
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-[var(--color-cream)]/85 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-cream)]/70 border-b border-black/5">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 md:px-10">
    <a href="/" class="font-display text-xl md:text-2xl tracking-tight" aria-label={`${SITE.name} home`}>
      The Pet Affaire
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-7 text-sm">
        {NAV.map((item) => {
          const active = path === item.href || path.startsWith(item.href + "/");
          return (
            <li>
              <a
                href={item.href}
                class={`hover:underline ${active ? "underline" : ""}`}
                aria-current={active ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={SITE.bookingUrl}
        class="hidden sm:inline-flex items-center rounded-full bg-[var(--color-ink)] px-4 py-2 text-sm text-[var(--color-cream)] hover:bg-black"
      >
        Book
      </a>
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-full border border-black/15 p-2"
        aria-label="Open menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    aria-label="Mobile"
    class="md:hidden hidden border-t border-black/5 bg-[var(--color-cream)]"
    data-menu-panel
  >
    <ul class="flex flex-col px-6 py-4">
      {NAV.map((item) => (
        <li>
          <a class="block py-2 text-base" href={item.href}>{item.label}</a>
        </li>
      ))}
      <li class="mt-2">
        <a class="inline-flex w-full justify-center rounded-full bg-[var(--color-ink)] px-4 py-3 text-sm text-[var(--color-cream)]" href={SITE.bookingUrl}>
          Book an appointment
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]");
  if (btn && panel) {
    btn.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(open));
    });
  }
</script>
