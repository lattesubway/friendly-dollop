---
import { getCollection, render } from "astro:content";

interface Props {
  featuredOnly?: boolean;
  limit?: number;
}
const { featuredOnly = false, limit } = Astro.props;

let items = await getCollection("reviews");
if (featuredOnly) items = items.filter((r) => r.data.featured);
items.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
if (limit) items = items.slice(0, limit);

const Stars = (n: number) => "★".repeat(n) + "☆".repeat(5 - n);
const single = items.length === 1;
---

{single ? (
  items.map(async (r) => {
    const { Content } = await render(r);
    return (
      <figure class="mx-auto max-w-3xl text-center">
        <div class="text-[var(--color-clay)] tracking-widest" aria-label={`${r.data.rating} out of 5`}>
          {Stars(r.data.rating)}
        </div>
        <blockquote class="mt-6 font-display text-2xl md:text-3xl leading-snug text-black/85">
          <Content />
        </blockquote>
        <figcaption class="mt-6 text-sm">
          <span class="font-medium">{r.data.author}</span>
          {r.data.pet && <span class="text-black/55"> · {r.data.pet}</span>}
          {r.data.source && <span class="ml-2 rounded-full border border-black/10 px-2 py-0.5 text-[11px] uppercase tracking-wider text-black/55">{r.data.source}</span>}
        </figcaption>
      </figure>
    );
  })
) : (
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {items.map(async (r) => {
      const { Content } = await render(r);
      return (
        <figure class="rounded-2xl border border-black/10 bg-white p-6 shadow-[0_1px_0_rgba(0,0,0,0.04)]">
          <div class="text-[var(--color-clay)] text-sm tracking-widest" aria-label={`${r.data.rating} out of 5`}>
            {Stars(r.data.rating)}
          </div>
          <blockquote class="mt-3 text-[15px] leading-relaxed text-black/80">
            <Content />
          </blockquote>
          <figcaption class="mt-4 text-sm">
            <span class="font-medium">{r.data.author}</span>
            {r.data.pet && <span class="text-black/55"> · {r.data.pet}</span>}
            {r.data.source && <span class="ml-2 rounded-full border border-black/10 px-2 py-0.5 text-[11px] uppercase tracking-wider text-black/55">{r.data.source}</span>}
          </figcaption>
        </figure>
      );
    })}
  </div>
)}
