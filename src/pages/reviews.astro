---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Reviews from "@/components/Reviews.astro";
import { SITE } from "@/consts";
---

<BaseLayout title="Reviews" description="Kind words from the humans (and pets) we work with.">
  <Section eyebrow="Reviews" title="What clients say.">
    <Reviews />
    <div class="mt-12 rounded-3xl border border-black/10 bg-white p-8 md:p-10">
      <h2 class="font-display text-2xl">Loved your visit?</h2>
      <p class="mt-2 max-w-xl text-black/70">
        A short review on Google or Yelp helps a small studio more than you might think.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="rounded-full bg-[var(--color-ink)] px-4 py-2 text-sm text-[var(--color-cream)]" href={SITE.social.google}>
          Leave a Google review
        </a>
        <a class="rounded-full border border-black/15 px-4 py-2 text-sm" href="/contact">
          Tell us directly
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
