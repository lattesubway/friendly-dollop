---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { SITE } from "@/consts";

// Replace with your provider's checkout URL once set up.
// Square Online (free) and Stripe Payment Links both work; pick one.
const giftCardUrl = "https://checkout.square.site/REPLACE_ME";
const denominations = [50, 75, 100, 150, 200, 250];
---

<BaseLayout title="Gift Cards" description="Give the gift of a calm groom. Digital gift cards for The Pet Affaire — Santa Monica.">
  <Section eyebrow="Gift cards" title="Give a calm groom.">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-6 space-y-5 text-[17px] leading-relaxed text-black/80">
        <p>
          Digital gift cards arrive by email and can be redeemed against any service — full grooms,
          baths, cat appointments, or add-ons.
        </p>
        <p>
          Need a gift wrapped in something more tangible? Email us at
          <a class="underline" href={`mailto:${SITE.email}`}>{SITE.email}</a> and we'll send a printed
          card to your address.
        </p>
        <ul class="grid grid-cols-3 gap-3 max-w-md">
          {denominations.map((d) => (
            <li>
              <a
                href={`${giftCardUrl}?amount=${d}`}
                class="flex aspect-[3/2] items-center justify-center rounded-2xl border border-black/10 bg-white text-lg font-medium hover:-translate-y-0.5 hover:shadow-md transition"
              >
                ${d}
              </a>
            </li>
          ))}
        </ul>
        <p class="pt-2">
          <a href={giftCardUrl} class="inline-flex items-center rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm text-[var(--color-cream)] hover:bg-black">
            Buy a gift card
          </a>
        </p>
      </div>

      <aside class="md:col-span-6">
        <div class="aspect-[3/2] rounded-3xl bg-gradient-to-br from-[var(--color-rose)] via-[var(--color-bone)] to-[var(--color-clay)] p-8 md:p-12 flex flex-col justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-black/55">A gift from</p>
            <p class="font-display text-3xl mt-2">The Pet Affaire</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-black/55">Redeemable for</p>
            <p class="font-display text-2xl mt-1">Any service · Any pet</p>
          </div>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>
