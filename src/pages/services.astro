---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const main = all.filter((s) => !s.data.addOn);
const dogs = main.filter((s) => s.data.species === "dog" || s.data.species === "both");
const cats = main.filter((s) => s.data.species === "cat" || s.data.species === "both");
const addOns = all.filter((s) => s.data.addOn);
---

<BaseLayout title="Services & Pricing" description="Cat and dog grooming services and add-ons at The Pet Affaire — Santa Monica.">
  <Section
    eyebrow="Services"
    title="A short list of services, done very well."
    intro="Every visit includes a thoughtful coat assessment, a gentle introduction to put your pet at ease, and a beautifully finished result that's carefully hand-checked before they head home."
  >
    <p class="-mt-6 mb-12 max-w-3xl text-base text-black/70">
      Pricing is thoughtfully determined by many variables — including breed, coat condition,
      size, and individual needs — so we're unable to list fixed rates here. Each price below is
      a starting point; we're happy to provide a personalized quote when you reach out.
    </p>

    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl border-b border-black/10 pb-3">For dogs</h2>
        <ul class="mt-6 space-y-6">
          {dogs.map((s) => (
            <li>
              <a href={`/services/${s.id}/`} class="group block rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="font-display text-2xl group-hover:underline">{s.data.title}</h3>
                  {s.data.priceFrom ? (
                    <p class="whitespace-nowrap text-sm">
                      <span class="text-black/55">from</span>
                      <span class="ml-1 font-medium">${s.data.priceFrom}</span>
                    </p>
                  ) : (
                    <p class="whitespace-nowrap text-xs uppercase tracking-wider text-black/45">Quoted in person</p>
                  )}
                </div>
                {s.data.duration && <p class="mt-1 text-xs uppercase tracking-wider text-black/50">{s.data.duration}</p>}
                <p class="mt-3 text-sm text-black/75">{s.data.summary}</p>
                {s.data.includes.length > 0 && (
                  <ul class="mt-4 space-y-1 text-sm text-black/70">
                    {s.data.includes.slice(0, 3).map((i) => <li class="flex gap-2"><span class="text-[var(--color-clay)]">·</span> {i}</li>)}
                    {s.data.includes.length > 3 && (
                      <li class="text-xs text-black/45">+{s.data.includes.length - 3} more</li>
                    )}
                  </ul>
                )}
                <p class="mt-4 text-sm underline underline-offset-4">Details & booking →</p>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="font-display text-2xl border-b border-black/10 pb-3">For cats</h2>
        <ul class="mt-6 space-y-6">
          {cats.map((s) => (
            <li>
              <a href={`/services/${s.id}/`} class="group block rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="font-display text-2xl group-hover:underline">{s.data.title}</h3>
                  {s.data.priceFrom ? (
                    <p class="whitespace-nowrap text-sm">
                      <span class="text-black/55">from</span>
                      <span class="ml-1 font-medium">${s.data.priceFrom}</span>
                    </p>
                  ) : (
                    <p class="whitespace-nowrap text-xs uppercase tracking-wider text-black/45">Quoted in person</p>
                  )}
                </div>
                {s.data.duration && <p class="mt-1 text-xs uppercase tracking-wider text-black/50">{s.data.duration}</p>}
                <p class="mt-3 text-sm text-black/75">{s.data.summary}</p>
                {s.data.includes.length > 0 && (
                  <ul class="mt-4 space-y-1 text-sm text-black/70">
                    {s.data.includes.slice(0, 3).map((i) => <li class="flex gap-2"><span class="text-[var(--color-clay)]">·</span> {i}</li>)}
                    {s.data.includes.length > 3 && (
                      <li class="text-xs text-black/45">+{s.data.includes.length - 3} more</li>
                    )}
                  </ul>
                )}
                <p class="mt-4 text-sm underline underline-offset-4">Details & booking →</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section bg="bone" eyebrow="Added Extras" title="Spa add-ons.">
    <p class="-mt-6 mb-8 max-w-2xl text-black/70 text-[15px]">
      Tell us which extras you'd like at booking, or add them on the day. The "+" indicates pricing
      may rise slightly with extra time, coat density, or product use.
    </p>
    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {addOns.map((s) => (
        <li>
          <a href={`/services/${s.id}/`} class="group flex h-full flex-col rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-display text-xl group-hover:underline">{s.data.title}</h3>
              {s.data.priceFrom && (
                <p class="whitespace-nowrap text-sm font-medium">${s.data.priceFrom}+</p>
              )}
            </div>
            <p class="mt-3 flex-1 text-sm text-black/70">{s.data.summary}</p>
            <p class="mt-4 text-xs underline underline-offset-4">Read more →</p>
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Good to know" title="A few honest notes.">
    <ul class="grid gap-6 md:grid-cols-2 text-[15px] leading-relaxed text-black/75">
      <li><strong class="text-black">Drop-off & pickup.</strong> Drop-off windows are 7:30 – 10:30 AM. Pickup at 2 PM. We don't kennel — your pet is with a groomer the whole time.</li>
      <li><strong class="text-black">One pet at a time.</strong> Every groom gets our full attention from check-in to pickup.</li>
      <li><strong class="text-black">Vaccinations.</strong> Rabies and DHPP for dogs, FVRCP for cats. Bring proof at the first visit.</li>
      <li><strong class="text-black">Late & no-show.</strong> A 50% fee for no-shows or cancellations under 24 hours, so we can keep prices fair.</li>
    </ul>
  </Section>
</BaseLayout>
