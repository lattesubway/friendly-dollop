---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Map from "@/components/Map.astro";
import PhotoBand from "@/components/PhotoBand.astro";
import { SITE } from "@/consts";
import { galleryItems } from "@/data/gallery";

const band = [galleryItems.pupSweater, galleryItems.tabby, galleryItems.pomMix];
---

<BaseLayout title="Contact" description="Reach The Pet Affaire by phone, email, or send a message — Santa Monica, California.">
  <Section eyebrow="Contact" title="Say hello.">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5 space-y-8">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-black/55">Visit</p>
          <address class="mt-3 not-italic text-base">
            {SITE.address.street}<br />
            {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}
          </address>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-black/55">Reach us</p>
          <p class="mt-3">
            <a class="hover:underline" href={SITE.phoneHref}>{SITE.phone}</a><br />
            <a class="hover:underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-black/55">Hours</p>
          <ul class="mt-3 space-y-1 text-sm">
            {SITE.hours.map((h) => (
              <li class="flex justify-between gap-6"><span>{h.day}</span><span class="text-black/60">{h.hours}</span></li>
            ))}
          </ul>
        </div>
        <p class="text-sm text-black/60">
          For appointments, please use <a class="underline" href="/book">Book an appointment</a> — it's the fastest way to a confirmed time.
        </p>
      </div>

      <div class="md:col-span-7">
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          data-netlify-recaptcha="true"
          netlify-honeypot="bot-field"
          action="/contact?sent=1"
          class="space-y-4 rounded-3xl border border-black/10 bg-white p-6 md:p-8"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="text-sm">Your name</span>
              <input required name="name" autocomplete="name" class="mt-1 w-full rounded-xl border border-black/15 bg-white px-3 py-2 focus:border-black/40 focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm">Email</span>
              <input required type="email" name="email" autocomplete="email" class="mt-1 w-full rounded-xl border border-black/15 bg-white px-3 py-2 focus:border-black/40 focus:outline-none" />
            </label>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="text-sm">Phone (optional)</span>
              <input type="tel" name="phone" autocomplete="tel" class="mt-1 w-full rounded-xl border border-black/15 bg-white px-3 py-2 focus:border-black/40 focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm">Pet & breed</span>
              <input name="pet" placeholder="e.g. Maple, mini-doodle" class="mt-1 w-full rounded-xl border border-black/15 bg-white px-3 py-2 focus:border-black/40 focus:outline-none" />
            </label>
          </div>

          <label class="block">
            <span class="text-sm">How can we help?</span>
            <textarea required name="message" rows="5" class="mt-1 w-full rounded-xl border border-black/15 bg-white px-3 py-2 focus:border-black/40 focus:outline-none"></textarea>
          </label>

          <div data-netlify-recaptcha="true"></div>

          <div class="flex items-center justify-between gap-4">
            <p class="text-xs text-black/55">We reply within one business day.</p>
            <button type="submit" class="rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm text-[var(--color-cream)] hover:bg-black">
              Send message
            </button>
          </div>
        </form>

        <p id="thanks" class="mt-4 hidden rounded-2xl bg-[var(--color-sage)]/30 p-4 text-sm" data-thanks>
          Thanks — your message is in. We'll be in touch within one business day.
        </p>
      </div>
    </div>
  </Section>

  <Section eyebrow="Studio life" title="A few faces from the studio." bg="sage" accent="sage">
    <PhotoBand items={band} aspect="square" />
  </Section>

  <Section eyebrow="Find us" title="On Lincoln, just south of Pico." bg="bone">
    <Map height="480px" />
    <p class="mt-6 max-w-2xl text-sm text-black/65">
      Street parking on Lincoln and on the side streets. We share the block with a small mix of
      shops — look for our sign and walk in.
    </p>
  </Section>

  <script>
    if (new URL(window.location.href).searchParams.get("sent") === "1") {
      const el = document.querySelector<HTMLElement>("[data-thanks]");
      if (el) el.classList.remove("hidden");
      const form = document.querySelector<HTMLFormElement>("form[name=contact]");
      form?.reset();
      el?.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  </script>
</BaseLayout>
