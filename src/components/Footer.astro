---
import { SITE, NAV } from "@/consts";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-black/10 bg-[var(--color-bone)]">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
    <div class="grid gap-12 md:grid-cols-4">
      <div class="md:col-span-2">
        <p class="font-display text-2xl tracking-tight">The Pet Affaire</p>
        <p class="mt-3 max-w-md text-sm text-black/70">
          Gentle grooming. Tail-wagging results. A Santa Monica studio for cats and dogs —
          hand-finished, fair-priced, and built on three decades of neighborhood trust.
        </p>

        <form
          name="newsletter"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="mt-6 flex max-w-md gap-2"
        >
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
          <label for="newsletter-email" class="sr-only">Email</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder="Your email — for occasional notes"
            class="flex-1 rounded-full border border-black/15 bg-white px-4 py-2 text-sm placeholder-black/40 focus:border-black/40 focus:outline-none"
          />
          <button
            type="submit"
            class="rounded-full bg-[var(--color-ink)] px-4 py-2 text-sm text-[var(--color-cream)] hover:bg-black"
          >
            Join
          </button>
        </form>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-black/50">Visit</p>
        <address class="mt-3 not-italic text-sm leading-relaxed">
          {SITE.address.street}<br />
          {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}
        </address>
        <p class="mt-3 text-sm">
          <a class="hover:underline" href={SITE.phoneHref}>{SITE.phone}</a><br />
          <a class="hover:underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-black/50">Hours</p>
        <ul class="mt-3 space-y-1 text-sm">
          {SITE.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.day}</span><span class="text-black/60">{h.hours}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-black/10 pt-6 text-xs text-black/55 md:flex-row md:items-center">
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <ul class="flex flex-wrap gap-x-5 gap-y-2">
        {NAV.map((n) => (
          <li><a class="hover:underline" href={n.href}>{n.label}</a></li>
        ))}
        <li><a class="hover:underline" href="/gift-cards">Gift Cards</a></li>
        <li><a class="hover:underline" href="/areas">Service Areas</a></li>
        <li><a class="hover:underline" href={SITE.social.instagram}>Instagram</a></li>
      </ul>
    </div>
  </div>
</footer>
