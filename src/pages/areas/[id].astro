---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import Reviews from "@/components/Reviews.astro";
import ReviewsSchema from "@/components/ReviewsSchema.astro";
import Map from "@/components/Map.astro";
import PhotoBand from "@/components/PhotoBand.astro";
import { SITE } from "@/consts";
import { galleryItems, type GalleryItem } from "@/data/gallery";

const heroByArea: Record<string, GalleryItem> = {
  "santa-monica": galleryItems.meetGreet,
  "pacific-palisades": galleryItems.poodle,
  venice: galleryItems.pomMix,
  brentwood: galleryItems.persian,
  "mar-vista": galleryItems.pupSweater,
};

const bandPhotos = [galleryItems.pomeranian, galleryItems.tabby, galleryItems.dachshund];

export async function getStaticPaths() {
  const areas = await getCollection("areas");
  return areas.map((area) => ({
    params: { id: area.id },
    props: { area },
  }));
}

interface Props { area: CollectionEntry<"areas">; }
const { area } = Astro.props;
const { data } = area;
const { Content } = await render(area);
const hero = heroByArea[area.id] ?? galleryItems.meetGreet;

const services = (await getCollection("services"))
  .filter((s) => !s.data.addOn)
  .sort((a, b) => a.data.order - b.data.order);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Service Areas", item: `${SITE.url}/areas` },
    { "@type": "ListItem", position: 3, name: data.title, item: Astro.url.toString() },
  ],
};

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "PetStore",
  "@id": `${SITE.url}#business`,
  name: SITE.name,
  url: SITE.url,
  areaServed: {
    "@type": "City",
    name: data.title,
    ...(data.neighborhoods.length > 0 && {
      containsPlace: data.neighborhoods.map((n) => ({
        "@type": "Place",
        name: n,
      })),
    }),
  },
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.title} — Cat & Dog Grooming`}
  description={data.seoDescription ?? data.intro}
>
  <section class="border-b border-black/5">
    <div class="mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-20">
      <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-[0.22em] text-black/55">
        <a href="/" class="hover:underline">Home</a>
        <span class="mx-2">·</span>
        <a href="/areas" class="hover:underline">Service Areas</a>
        <span class="mx-2">·</span>
        <span>{data.title}</span>
      </nav>

      <div class="mt-8 grid gap-12 md:grid-cols-12">
        <div class="md:col-span-7">
          <p class="text-xs uppercase tracking-[0.22em] text-[color-mix(in_oklab,var(--color-sage)_85%,var(--color-ink))]">
            Serving {data.title}
          </p>
          <h1 class="mt-3 font-display text-5xl md:text-6xl leading-[1.02]">{data.headline}</h1>
          <p class="mt-6 max-w-xl text-lg text-black/75">{data.intro}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/book" class="rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm text-[var(--color-cream)] hover:bg-black">
              Book an appointment
            </a>
            <a href={SITE.mapDirectionsGoogle} class="rounded-full border border-black/15 px-5 py-3 text-sm hover:border-black/40">
              Get directions
            </a>
          </div>
        </div>

        <aside class="md:col-span-5">
          <div class="relative">
            <span
              aria-hidden="true"
              class="absolute inset-0 -z-10 rounded-3xl bg-[var(--color-sage)] opacity-40 translate-x-3 translate-y-3 md:translate-x-4 md:translate-y-4"
            ></span>
            <svg
              aria-hidden="true"
              viewBox="0 0 64 64"
              class="pointer-events-none absolute -top-7 -right-5 h-20 w-20 rotate-[18deg] text-[var(--color-sage)] opacity-65 md:h-24 md:w-24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
            >
              <ellipse cx="32" cy="44" rx="14" ry="11" />
              <ellipse cx="13" cy="26" rx="5" ry="7" />
              <ellipse cx="25" cy="14" rx="5" ry="7" />
              <ellipse cx="39" cy="14" rx="5" ry="7" />
              <ellipse cx="51" cy="26" rx="5" ry="7" />
            </svg>
            <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-[var(--color-bone)]">
              <Picture
                src={hero.src}
                formats={["avif", "webp"]}
                alt={hero.alt}
                widths={[400, 600, 800, 1000]}
                sizes="(max-width: 768px) 100vw, 42vw"
                loading="eager"
                decoding="async"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Section eyebrow="Getting here" title={`From ${data.title} to our door.`} bg="bone" accent="sage">
    <div class="grid items-stretch gap-10 md:grid-cols-12">
      <div class="md:col-span-7">
        <Map height="380px" />
      </div>
      <div class="md:col-span-5 space-y-6">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-black/55">Drive note</p>
          <p class="mt-2 text-[15px] leading-relaxed text-black/80">{data.driveNote}</p>
        </div>
        {data.landmarks.length > 0 && (
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-black/55">Nearby</p>
            <ul class="mt-2 space-y-1 text-[15px] text-black/75">
              {data.landmarks.map((l) => (
                <li class="flex gap-2"><span class="text-[var(--color-clay)]">·</span><span>{l}</span></li>
              ))}
            </ul>
          </div>
        )}
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-black/55">Address</p>
          <p class="mt-2 text-[15px] text-black/80">
            {SITE.address.street}<br />
            {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section eyebrow="A bit about the area" title={`What we hear from ${data.title} clients.`} accent="sage">
    <div class="prose prose-neutral max-w-2xl text-[17px] leading-relaxed">
      <Content />
    </div>
    {data.neighborhoods.length > 0 && (
      <div class="mt-12">
        <p class="text-xs uppercase tracking-[0.22em] text-black/55">Neighborhoods we see often</p>
        <ul class="mt-4 flex flex-wrap gap-2">
          {data.neighborhoods.map((n) => (
            <li class="rounded-full border border-black/15 bg-white px-3 py-1 text-sm">{n}</li>
          ))}
        </ul>
      </div>
    )}
  </Section>

  <Section eyebrow="From the studio" title="Recent visitors." bg="sage" accent="sage">
    <PhotoBand items={bandPhotos} aspect="square" />
    <p class="mt-6 text-sm text-black/55">
      More in the <a href="/gallery" class="underline underline-offset-4 hover:text-black">gallery</a>.
    </p>
  </Section>

  <Section eyebrow="Services" title="Everything we offer." bg="bone" accent="sage">
    <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <li>
          <a href={`/services/${s.id}/`} class="group flex h-full flex-col rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-display text-xl group-hover:underline">{s.data.title}</h3>
              <span class="rounded-full border border-black/10 px-2 py-0.5 text-[11px] uppercase tracking-wider text-black/55">
                {s.data.species === "both" ? "all" : s.data.species}
              </span>
            </div>
            <p class="mt-3 flex-1 text-sm text-black/70">{s.data.summary}</p>
            {s.data.priceFrom && (
              <p class="mt-4 text-sm">
                <span class="text-black/55">From</span>
                <span class="ml-1 font-medium">${s.data.priceFrom}</span>
              </p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="What clients say" title="Kind words from kind humans." bg="rose" accent="rose">
    <Reviews featuredOnly limit={3} />
    <ReviewsSchema includeReviews featuredOnly />
  </Section>

  <Section bg="ink">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div>
        <h2 class="font-display text-4xl md:text-5xl leading-tight">Bring them down from {data.title}.</h2>
        <p class="mt-4 max-w-md text-current/75">Live availability, instant confirmation, friendly reminders.</p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a href="/book" class="rounded-full bg-[var(--color-cream)] px-5 py-3 text-sm text-[var(--color-ink)] hover:bg-white">Book now</a>
        <a href={SITE.phoneHref} class="rounded-full border border-white/30 px-5 py-3 text-sm hover:border-white/70">Call {SITE.phone}</a>
      </div>
    </div>
  </Section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(areaSchema)} />
</BaseLayout>
