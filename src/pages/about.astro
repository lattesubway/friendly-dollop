---
import { Picture } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { galleryItems } from "@/data/gallery";
const meetGreet = galleryItems.meetGreet.src;
---

<BaseLayout title="About" description="A neighborhood grooming studio in Santa Monica — gentle handling, expert finish, fair prices. For cats, dogs, and the families who love them.">
  <Section eyebrow="A little about us" title="We call our spa &lsquo;The Pet Affaire&rsquo;.">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-7 space-y-5 text-[17px] leading-relaxed text-black/80">
        <p class="font-display text-2xl text-black/85 italic">
          It's more than just grooming. It's our art form.
        </p>
        <p>
          The Pet Affaire is a small grooming studio in Santa Monica, and we've been part of this
          neighborhood for a long time. The work hasn't changed because the things we care about
          haven't changed: how the pet feels, how the groom looks, and whether you can afford to
          come back.
        </p>
        <p>
          <strong class="text-black">Gentle, safe, calm.</strong> The first job is always how the
          animal feels. We work slowly, read the pet in front of us, and stop when stopping is the
          right call. No all-day waits, no rushed hands.
        </p>
        <p>
          <strong class="text-black">Precision and craft.</strong> Our groomers have built a
          reputation one dog and one cat at a time. Scissor finishing on every cut, a real eye for
          line and proportion, and the patience to do it right.
        </p>
        <p>
          <strong class="text-black">Community and fair value.</strong> We've watched a lot of pet
          spas in Los Angeles drift toward assembly-line work at boutique prices. We've gone the
          other direction: keep the quality high, keep the prices honest, treat every client like
          a neighbor. Most of ours have been with us for years — some for decades.
        </p>
      </div>
      <aside class="md:col-span-5">
        <div class="relative">
          <span
            aria-hidden="true"
            class="absolute inset-0 -z-10 rounded-3xl bg-[var(--color-rose)] opacity-45 translate-x-3 translate-y-3 md:translate-x-4 md:translate-y-4"
          ></span>
          <svg
            aria-hidden="true"
            viewBox="0 0 64 64"
            class="pointer-events-none absolute -top-7 -right-5 h-20 w-20 rotate-[18deg] text-[var(--color-clay)] opacity-55 md:h-24 md:w-24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
          >
            <ellipse cx="32" cy="44" rx="14" ry="11" />
            <ellipse cx="13" cy="26" rx="5" ry="7" />
            <ellipse cx="25" cy="14" rx="5" ry="7" />
            <ellipse cx="39" cy="14" rx="5" ry="7" />
            <ellipse cx="51" cy="26" rx="5" ry="7" />
          </svg>
          <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-[var(--color-bone)]">
            <Picture
              src={meetGreet}
              formats={["avif", "webp"]}
              alt="A cream Shih Tzu and a small black puppy saying hello after their groom at The Pet Affaire."
              widths={[400, 600, 800, 1000]}
              sizes="(max-width: 768px) 100vw, 42vw"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </aside>
    </div>
  </Section>

  <Section eyebrow="Our Pet Affaire Promise" title="Calm hands. Glowing coats. Trust that builds, one groom at a time." bg="rose" accent="rose">
    <ul class="grid gap-6 md:grid-cols-3">
      <li class="rounded-3xl border border-black/10 bg-white p-7">
        <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-clay)]">Hypoallergenic care</p>
        <h3 class="mt-3 font-display text-2xl">Top-tier products, tailored.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-black/75">
          We use hypoallergenic, top-tier grooming products chosen to meet your pet's specific
          sensitivities — from the shampoo on their skin to the conditioner left in.
        </p>
      </li>
      <li class="rounded-3xl border border-black/10 bg-white p-7">
        <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-clay)]">Spa, not assembly line</p>
        <h3 class="mt-3 font-display text-2xl">They leave glowing.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-black/75">
          From deep conditioning treatments to calming aromatherapy rinses, your pet leaves the
          studio softer, brighter, and more relaxed than when they arrived.
        </p>
      </li>
      <li class="rounded-3xl border border-black/10 bg-white p-7">
        <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-clay)]">Empathy, always</p>
        <h3 class="mt-3 font-display text-2xl">We meet pets where they are.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-black/75">
          From shy rescues to high-energy pups, we adjust our pace and handling with empathy.
          Our calm, loving process builds trust — one groom at a time.
        </p>
      </li>
    </ul>
    <p class="mt-12 font-display text-2xl md:text-3xl italic text-black/85 max-w-3xl">
      Grooming That Respects. Every Pet. Every Time.
    </p>
  </Section>

  <Section eyebrow="Our promises" title="What we'll always do.">
    <ul class="grid gap-6 md:grid-cols-2 text-[15px] leading-relaxed text-black/75">
      <li><strong class="text-black">Hand-finished.</strong> Scissor finishing on every cut, every time.</li>
      <li><strong class="text-black">Honest pricing.</strong> If a groom is going to cost more, you'll hear it before we begin — never after.</li>
      <li><strong class="text-black">Welfare-first.</strong> If a groom isn't safe to finish, we stop and explain why. We don't push through for the sake of a finished cut.</li>
      <li><strong class="text-black">Open communication.</strong> Real-time texts on arrival, mid-groom, and ready-for-pickup so nothing surprises you.</li>
    </ul>
  </Section>
</BaseLayout>
