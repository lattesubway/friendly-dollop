---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { SITE } from "@/consts";

import pomeranian from "@/assets/gallery/01-pomeranian.jpg";
import pomMix from "@/assets/gallery/02-pom-mix.jpg";
import tabby from "@/assets/gallery/03-tabby-cat.jpg";
import persian from "@/assets/gallery/04-persian-chair.jpg";
import dachshund from "@/assets/gallery/05-dachshund.jpg";
import poodle from "@/assets/gallery/06-poodle-holiday.jpg";
import meetGreet from "@/assets/gallery/09-meet-and-greet.jpg";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { id: service.id },
    props: { service },
  }));
}

interface Props { service: CollectionEntry<"services">; }
const { service } = Astro.props;
const { data } = service;
const { Content } = await render(service);

const all = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const related = all
  .filter((s) => s.id !== service.id && (s.data.species === data.species || s.data.species === "both" || data.species === "both"))
  .slice(0, 3);

const speciesLabel = data.species === "dog" ? "Dogs" : data.species === "cat" ? "Cats" : "Cats & Dogs";

const accentVar = data.species === "dog"
  ? "var(--color-sage)"
  : data.species === "cat"
  ? "var(--color-rose)"
  : "var(--color-clay)";

const steps = [
  { title: "Welcome", body: "Drop-off, gentle introduction, coat & skin check." },
  { title: "Bath", body: "Premium hypoallergenic products, warm water, calm hands." },
  { title: "Service", body: `${data.title.toLowerCase()} — done thoroughly, never rushed.` },
  { title: "Pickup", body: "Hand-checked, brushed, and ready for home." },
];

const galleryBySpecies = {
  dog: [
    { src: pomeranian, alt: "Silver Pomeranian relaxing, freshly fluffed.", caption: "Pomeranian · freshly fluffed" },
    { src: dachshund, alt: "Black and tan dapple dachshund, sleek and shiny.", caption: "Dachshund · sleek & shiny" },
    { src: poodle, alt: "White poodle photographed in black and white by a Christmas tree.", caption: "Holiday poodle" },
  ],
  cat: [
    { src: tabby, alt: "Long-haired tabby cat with green eyes, freshly groomed.", caption: "Long-haired tabby · post-groom" },
    { src: persian, alt: "White Persian cat on an ornate silver tufted chair.", caption: "Persian · royalty" },
    { src: meetGreet, alt: "Cream Shih Tzu and a small black puppy saying hello.", caption: "Studio mornings" },
  ],
  both: [
    { src: pomMix, alt: "Black and tan Pomeranian mix with bright eyes.", caption: "Pom mix · bright eyes" },
    { src: tabby, alt: "Long-haired tabby cat with green eyes, freshly groomed.", caption: "Long-haired tabby · post-groom" },
    { src: poodle, alt: "White poodle photographed in black and white by a Christmas tree.", caption: "Holiday poodle" },
  ],
};
const galleryPhotos = galleryBySpecies[data.species] ?? galleryBySpecies.both;
const galleryTitle = data.species === "cat"
  ? "Recent feline visitors."
  : data.species === "dog"
  ? "Recent canine visitors."
  : "Recent visitors.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: data.title,
  name: data.title,
  description: data.summary,
  provider: { "@id": `${SITE.url}#business` },
  areaServed: { "@type": "City", name: "Santa Monica" },
  audience: { "@type": "PeopleAudience", audienceType: speciesLabel },
  ...(data.priceFrom && {
    offers: {
      "@type": "Offer",
      price: data.priceFrom,
      priceCurrency: "USD",
      priceSpecification: {
        "@type": "PriceSpecification",
        price: data.priceFrom,
        priceCurrency: "USD",
        valueAddedTaxIncluded: false,
        description: "Starting price; final price set in person.",
      },
      availability: "https://schema.org/InStock",
      url: `${SITE.url}/book`,
    },
  }),
};

const faqSchema = data.faq.length > 0 && {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: data.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Services", item: `${SITE.url}/services` },
    { "@type": "ListItem", position: 3, name: data.title, item: Astro.url.toString() },
  ],
};
---

<BaseLayout
  title={data.seoTitle ?? data.title}
  description={data.seoDescription ?? data.summary}
>
  <section class="border-b border-black/5">
    <div class="mx-auto max-w-7xl px-6 py-12 md:px-10 md:py-16">
      <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-[0.22em] text-black/55">
        <a href="/" class="hover:underline">Home</a>
        <span class="mx-2">·</span>
        <a href="/services" class="hover:underline">Services</a>
        <span class="mx-2">·</span>
        <span>{data.title}</span>
      </nav>

      <div class="mt-8 grid gap-12 md:grid-cols-12">
        <div class="md:col-span-8">
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-clay)]">For {speciesLabel}</p>
          <h1 class="mt-3 font-display text-5xl md:text-6xl leading-[1.02]">{data.title}</h1>
          <p class="mt-5 max-w-xl text-lg text-black/75">{data.summary}</p>

          <dl class="mt-8 grid grid-cols-2 gap-6 text-sm sm:grid-cols-3">
            {data.priceFrom && (
              <div>
                <dt class="text-black/50">From</dt>
                <dd class="mt-1 font-medium">${data.priceFrom}</dd>
              </div>
            )}
            {data.duration && (
              <div>
                <dt class="text-black/50">Duration</dt>
                <dd class="mt-1 font-medium">{data.duration}</dd>
              </div>
            )}
            <div>
              <dt class="text-black/50">For</dt>
              <dd class="mt-1 font-medium">{speciesLabel}</dd>
            </div>
          </dl>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/book" class="rounded-full bg-[var(--color-ink)] px-5 py-3 text-sm text-[var(--color-cream)] hover:bg-black">
              Book this service
            </a>
            <a href="/contact" class="rounded-full border border-black/15 px-5 py-3 text-sm hover:border-black/40">
              Ask a question
            </a>
          </div>
        </div>

        <aside class="md:col-span-4">
          <div class="relative" style={`--accent: ${accentVar}`}>
            <span
              aria-hidden="true"
              class="absolute inset-0 -z-10 rounded-3xl bg-[var(--accent)] opacity-40 translate-x-3 translate-y-3 md:translate-x-4 md:translate-y-4"
            ></span>
            <svg
              aria-hidden="true"
              viewBox="0 0 64 64"
              class="pointer-events-none absolute -top-7 -right-5 h-20 w-20 rotate-[18deg] text-[var(--accent)] opacity-60 md:h-24 md:w-24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
            >
              <ellipse cx="32" cy="44" rx="14" ry="11" />
              <ellipse cx="13" cy="26" rx="5" ry="7" />
              <ellipse cx="25" cy="14" rx="5" ry="7" />
              <ellipse cx="39" cy="14" rx="5" ry="7" />
              <ellipse cx="51" cy="26" rx="5" ry="7" />
            </svg>
            <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-[var(--color-bone)]">
              {data.cover ? (
                <img src={data.cover} alt={data.title} class="h-full w-full object-cover" loading="eager" />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-[var(--color-rose)] via-[var(--color-bone)] to-[var(--color-sage)]">
                  <span class="font-display text-2xl text-black/40">{data.title}</span>
                </div>
              )}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {!data.addOn && (
    <section class="border-b border-black/5">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-20">
        <p class="text-xs uppercase tracking-[0.22em] text-black/55">How it goes</p>
        <h2 class="mt-4 font-display text-3xl md:text-4xl leading-[1.05]">From drop-off to home, calmly.</h2>
        <ol class="mt-12 grid gap-10 md:grid-cols-4 md:gap-6">
          {steps.map((step, i) => (
            <li>
              <div class="flex items-center gap-3">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[var(--color-cream)] font-display text-base text-[var(--color-clay)] ring-1 ring-black/15">
                  {String(i + 1).padStart(2, "0")}
                </span>
                {i < steps.length - 1 && (
                  <span aria-hidden="true" class="hidden h-px flex-1 bg-black/15 md:block"></span>
                )}
              </div>
              <h3 class="mt-5 font-display text-xl">{step.title}</h3>
              <p class="mt-2 text-sm text-black/70">{step.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  {data.includes.length > 0 && (
    <Section eyebrow="What's included" title="Every visit includes:" bg="bone">
      <ul class="grid gap-3 md:grid-cols-2">
        {data.includes.map((i) => (
          <li class="flex gap-3 rounded-2xl border border-black/10 bg-white p-4 text-[15px]">
            <span class="text-[var(--color-clay)]">·</span>
            <span>{i}</span>
          </li>
        ))}
      </ul>
      {data.priceNote && <p class="mt-6 text-sm text-black/55">{data.priceNote}</p>}
    </Section>
  )}

  <Section eyebrow="The detail" title="A bit more about this service.">
    <div class="prose prose-neutral max-w-2xl text-[17px] leading-relaxed">
      <Content />
    </div>
  </Section>

  <Section eyebrow="From the studio" title={galleryTitle}>
    <ul class="grid grid-cols-3 gap-3 md:gap-4">
      {galleryPhotos.map((p) => (
        <li class="overflow-hidden rounded-2xl bg-[var(--color-bone)]">
          <figure class="group relative aspect-square">
            <Picture
              src={p.src}
              formats={["avif", "webp"]}
              alt={p.alt}
              widths={[240, 360, 480]}
              sizes="(max-width: 640px) 33vw, (max-width: 1024px) 25vw, 240px"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
            />
            <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-3 text-[11px] uppercase tracking-wider text-white opacity-0 transition group-hover:opacity-100">
              {p.caption}
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>
    <p class="mt-6 text-sm text-black/55">
      See more in the <a href="/gallery" class="underline underline-offset-4 hover:text-black">full gallery</a>.
    </p>
  </Section>

  {data.faq.length > 0 && (
    <Section eyebrow="FAQ" title="Common questions." bg="bone">
      <ul class="divide-y divide-black/10 rounded-3xl border border-black/10 bg-white">
        {data.faq.map((f) => (
          <li class="p-6">
            <details class="group">
              <summary class="flex cursor-pointer items-start justify-between gap-4 list-none">
                <span class="font-display text-xl">{f.q}</span>
                <span class="text-black/40 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-3 text-[15px] leading-relaxed text-black/75">{f.a}</p>
            </details>
          </li>
        ))}
      </ul>
    </Section>
  )}

  {related.length > 0 && (
    <Section eyebrow="Other services" title="You might also need:">
      <ul class="grid gap-6 md:grid-cols-3">
        {related.map((r) => (
          <li>
            <a href={`/services/${r.id}/`} class="group block rounded-2xl border border-black/10 bg-white p-6 transition hover:-translate-y-0.5 hover:shadow-md">
              <h3 class="font-display text-2xl group-hover:underline">{r.data.title}</h3>
              <p class="mt-2 text-sm text-black/70">{r.data.summary}</p>
              {r.data.priceFrom && (
                <p class="mt-3 text-sm">
                  <span class="text-black/55">From</span>
                  <span class="ml-1 font-medium">${r.data.priceFrom}</span>
                </p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </Section>
  )}

  <Section bg="ink">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div>
        <h2 class="font-display text-4xl md:text-5xl leading-tight">Book {data.title.toLowerCase()}.</h2>
        <p class="mt-4 max-w-md text-current/75">Live availability, instant confirmation, friendly reminders.</p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a href="/book" class="rounded-full bg-[var(--color-cream)] px-5 py-3 text-sm text-[var(--color-ink)] hover:bg-white">Book now</a>
        <a href={SITE.phoneHref} class="rounded-full border border-white/30 px-5 py-3 text-sm hover:border-white/70">Call {SITE.phone}</a>
      </div>
    </div>
  </Section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</BaseLayout>
